<% layout('/layouts/boilerplate') -%>

  <div class="container my-5">
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-6">

        <div class="card shadow-lg listing-show-card">

          <% let imageUrl=listing.image?.url || listing.image; %>
            <% if(imageUrl) { %>
              <img src="<%= imageUrl %>" class="card-img-top show-img" alt="listing image">
              <% } %>

                <div class="card-body">
                  <p class="card-text text-muted">Owner:<%= listing.owner.username %>
                  </p>

                  <h3 class="card-title mb-3">
                    <%= listing.title %>
                  </h3>

                  <p class="card-text text-muted">
                    <%= listing.description %>
                  </p>

                  <h5 class="price mt-3">
                    ₹ <%= listing.price.toLocaleString("en-IN") %>
                  </h5>

                  <p class="location mt-2">
                    <%= listing.location %>, <%= listing.country %>
                  </p>

                  <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
                    <div class="d-flex gap-2 mt-4">

                      <form action="/listings/<%= listing._id %>/edit" method="GET">
                        <button class="btn btn-outline-dark btn-sm">
                          Edit
                        </button>
                      </form>

                      <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-danger btn-sm">
                          Delete
                        </button>
                      </form>

                    </div>
                    <% } %>
                </div>

        </div>

        <div class="mt-5 mb-4 p-4 border rounded shadow-sm bg-light">
          <h4 class="mb-3"><i class="fa-solid fa-pen-to-square me-2"></i>Leave a Review</h4>
          <% if(currUser) { %>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation">
              <div class="mb-3">
                <label class="form-label fw-bold">Rating</label>
                <div class="star-rating">
                  <input type="radio" id="star5" name="review[rating]" value="5" />
                  <label for="star5" title="5 stars">&#9733;</label>

                  <input type="radio" id="star4" name="review[rating]" value="4" />
                  <label for="star4" title="4 stars">&#9733;</label>

                  <input type="radio" id="star3" name="review[rating]" value="3" />
                  <label for="star3" title="3 stars">&#9733;</label>

                  <input type="radio" id="star2" name="review[rating]" value="2" />
                  <label for="star2" title="2 stars">&#9733;</label>

                  <input type="radio" id="star1" name="review[rating]" value="1" checked />
                  <label for="star1" title="1 star">&#9733;</label>
                </div>
              </div>
              <div class="mb-3">
                <label for="comment" class="form-label fw-bold">Comments</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control"
                  placeholder="Write your experience here..." required></textarea>
                <div class="invalid-feedback">
                  Please add some comments for your review.
                </div>
              </div>
              <button type="submit" class="btn btn-outline-dark fw-bold">Submit Review</button>
            </form>
            <% } %>

              <h4 class="mb-4"><i class="fa-solid fa-comments me-2"></i>All Reviews</h4>
              <% if(listing.reviews && listing.reviews.length> 0) { %>
                <hr class="my-5">
                <div class="row">
                  <% for(let review of listing.reviews) { %>
                    <div class="col-md-6 mb-3">
                      <div class="card shadow-sm h-100 border-0">
                        <div class="card-body">
                          <p class="card-subtitle mb-2 text-warning fs-5">
                            <% for(let i=0; i < review.rating; i++) { %>&#9733;<% } %>
                                <% for(let i=review.rating; i < 5; i++) { %>
                                  <span class="text-muted">&#9733;</span>
                                  <% } %>
                          </p>
                          <p class="card-text text-secondary mb-1">
                            <%= review.comment %>
                          </p>
                          <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                            method="POST">
                            <button class="btn btn-danger btn-sm">Delete</button>
                          </form>
                        </div>
                      </div>
                    </div>
                    <% } %>
                </div>
                <% } %>

        </div>
      </div>
    </div>
  </div>
  </div>